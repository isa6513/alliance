doctype html
html(lang="en")
  head
    meta(charset="UTF-8")
    meta(name="viewport" content="width=device-width, initial-scale=1.0")
    title New comments

  body
      p Hello #{name},
      p You have #{count} new comments on your posts or activities.

      p You can see and reply to them by visiting the link below:
      p #{url}