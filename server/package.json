{
  "name": "server",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "type": "commonjs",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "print:node": "node -v && node -p 'process.execPath'",
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "typecheck": "tsc --noEmit",
    "test": "bun test src/",
    "test:watch": "bun test --watch src/",
    "test:cov": "bun test --coverage src/",
    "test:e2e": "bun test ./test/*.e2e-spec.ts --timeout 50000 --concurrency 1",
    "typeorm": "npx typeorm-ts-node-commonjs --dataSource dist/datasources/dataSourceMigrations.js",
    "migration:generate": "npm run migration:run && npm run typeorm -- migration:generate",
    "migration:create": "npm run migration:run && npx typeorm-ts-node-commonjs migration:create",
    "migration:runprod": "npx typeorm --dataSource dist/datasources/dataSource.js migration:run",
    "migration:run": "npm run build && npm run typeorm -- migration:run",
    "migration:revert": "npm run typeorm -- migration:revert",
    "test:agents": "./scripts/test-in-container.sh"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.842.0",
    "@aws-sdk/s3-request-presigner": "^3.842.0",
    "@js-temporal/polyfill": "^0.5.1",
    "@nestjs-modules/mailer": "^2.0.2",
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.0.1",
    "@nestjs/event-emitter": "^3.0.1",
    "@nestjs/jwt": "^11.0.0",
    "@nestjs/mapped-types": "*",
    "@nestjs/platform-express": "^11.0.1",
    "@nestjs/platform-socket.io": "^11.1.3",
    "@nestjs/schedule": "^6.0.0",
    "@nestjs/swagger": "^11.1.5",
    "@nestjs/typeorm": "^11.0.0",
    "@nestjs/websockets": "^11.1.3",
    "@typescript-eslint/parser": "^8.37.0",
    "bcrypt": "^5.1.1",
    "bcryptjs": "^3.0.2",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "cookie-parser": "^1.4.7",
    "date-fns": "^4.1.0",
    "expo-server-sdk": "^4.0.0",
    "libphonenumber-js": "^1.12.17",
    "nodemailer": "^7.0.3",
    "pg": "^8.15.5",
    "postgres": "^3.4.5",
    "posthog-node": "^5.7.0",
    "prom-client": "^15.1.3",
    "pug": "^3.0.3",
    "readline": "^1.3.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "sharp": "^0.34.3",
    "socket.io": "^4.8.1",
    "stripe": "^18.0.0",
    "twilio": "^5.9.0",
    "typeorm": "^0.3.25"
  },
  "devDependencies": {
    "@darraghor/eslint-plugin-nestjs-typed": "^6.7.0",
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.25.1",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@swc/cli": "^0.6.0",
    "@swc/core": "^1.15.2",
    "@types/cookie-parser": "^1.4.8",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.14",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.10.7",
    "@types/nodemailer": "^6.4.17",
    "@types/passport-local": "^1.0.38",
    "@types/sharp": "^0.31.1",
    "@types/supertest": "^6.0.2",
    "eslint": "^9.25.1",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "globals": "^16.0.0",
    "prettier": "^3.4.2",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.33.0"
  }
}