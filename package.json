{
  "private": true,
  "name": "alliance",
  "version": "0.0.0",
  "workspaces": [
    "apps/frontend",
    "apps/admin",
    "apps/mobile",
    "citesting",
    "shared",
    "sharedweb"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "frontend:dev": "yarn workspace @alliance/frontend dev",
    "admin:dev": "yarn workspace @alliance/admin dev",
    "server:dev": "cd server && bun dev",
    "gen-api": "yarn workspace @alliance/shared gen-api",
    "eas-build-pre-install": "corepack enable && corepack prepare yarn@4.9.1 --activate"
  },
  "devDependencies": {
    "@eslint/js": "^9.28.0",
    "eslint": "^9.28.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.33.0"
  },
  "packageManager": "yarn@4.9.1",
  "dependencies": {
    "@tanstack/react-query": "^5.90.20",
    "lucide-react": "^0.563.0",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "react-markdown": "^10.1.0",
    "socket.io-client": "^4.8.1"
  },
  "resolutions": {
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "react-test-renderer": "19.0.0",
    "react-native-renderer": "19.0.0"
  }
}
