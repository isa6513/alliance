{
  "private": true,
  "name": "alliance",
  "version": "0.0.0",
  "packageManager": "bun@1.3.6",
  "workspaces": [
    "apps/admin",
    "apps/frontend",
    "apps/mobile",
    "citesting",
    "common",
    "server",
    "shared",
    "sharedweb"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "frontend:dev": "bun run --cwd apps/frontend dev",
    "admin:dev": "bun run --cwd apps/admin dev",
    "server:dev": "cd server && bun dev",
    "gen-api": "bun run --cwd shared gen-api",
    "eas-build-pre-install": "bun install --frozen-lockfile"
  },
  "devDependencies": {
    "@eslint/js": "^9.28.0",
    "eslint": "^9.28.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.33.0"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.90.20",
    "lucide-react": "^0.563.0",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "react-markdown": "^10.1.0",
    "react-native-reanimated": "4.2.2",
    "socket.io-client": "^4.8.1"
  },
  "overrides": {
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "react-test-renderer": "19.0.0",
    "react-native-renderer": "19.0.0",
    "@types/react": "19.1.6"
  }
}
