# Frontend env vars. Copy this file to `.env.local` for local development:

# Cloudflare Turnstile site key for the signup captcha.
# Leave unset to hide the widget entirely (server verification is also opt-in).
# Use Cloudflare's test keys locally — they need no domain allowlist:
#   1x00000000000000000000AA  always passes (recommended for dev)
#   3x00000000000000000000FF  always shows interactive challenge
#   2x00000000000000000000AB  always blocks (to exercise the error UI)
VITE_TURNSTILE_SITE_KEY=1x00000000000000000000AA
