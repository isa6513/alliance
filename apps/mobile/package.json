{
  "name": "@alliance/mobile",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "packageManager": "yarn@4.9.1",
  "installConfig": {
    "hoistingLimits": "workspaces"
  },
  "scripts": {
    "start": "expo start --dev-client",
    "reset-project": "node ./scripts/reset-project.js",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "lint": "expo lint",
    "gen-api": "yarn openapi-ts",
    "eas-build-pre-install": "corepack enable && corepack prepare yarn@4.9.1 --activate",
    "build:simulator": "npx expo prebuild && cd ios && pod install && cd .. && npx expo run:ios",
    "build:device": "npx expo prebuild && cd ios && pod install && cd .. && npx expo run:ios --device 00008030-001514A021B9802E",
    "build:android": "npx expo prebuild -p android && npx expo run:android",
    "buildprod": "npx expo prebuild --clean && cd ios && pod repo update && pod install && cd .. && open ios/*.xcworkspace"
  },
  "dependencies": {
    "@alliance/shared": "workspace:*",
    "@hey-api/client-fetch": "^0.10.0",
    "@legendapp/list": "^2.0.19",
    "@react-navigation/bottom-tabs": "^7.3.10",
    "@react-navigation/drawer": "^7.8.0",
    "@react-navigation/elements": "^2.9.5",
    "@react-navigation/native": "^7.1.28",
    "@react-navigation/native-stack": "^7.4.4",
    "@tanstack/react-query": "^5.90.20",
    "expo": "~53.0.9",
    "expo-application": "~6.1.5",
    "expo-blur": "~14.1.4",
    "expo-constants": "~17.1.8",
    "expo-dev-client": "~5.2.4",
    "expo-device": "~7.1.4",
    "expo-file-system": "~18.1.11",
    "expo-font": "~13.3.2",
    "expo-haptics": "~14.1.4",
    "expo-image": "~2.4.1",
    "expo-image-picker": "~16.1.4",
    "expo-linking": "~7.1.5",
    "expo-localization": "~16.1.6",
    "expo-notifications": "~0.31.4",
    "expo-router": "~5.1.10",
    "expo-secure-store": "^14.2.3",
    "expo-splash-screen": "~0.30.8",
    "expo-status-bar": "~2.2.3",
    "expo-symbols": "~0.4.4",
    "expo-system-ui": "~5.0.7",
    "expo-web-browser": "~14.2.0",
    "lucide-react-native": "^0.562.0",
    "posthog-react-native": "^4.17.2",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "react-native": "0.79.6",
    "react-native-gesture-handler": "~2.24.0",
    "react-native-keyboard-controller": "^1.20.4",
    "react-native-localize": "^3.6.1",
    "react-native-markdown-display": "^7.0.2",
    "react-native-reanimated": "~3.17.4",
    "react-native-safe-area-context": "5.4.0",
    "react-native-screens": "~4.11.1",
    "react-native-svg": "15.11.2",
    "react-native-web": "~0.20.0",
    "react-native-webview": "13.13.5",
    "tailwindcss": "^4.1.18",
    "uniwind": "^1.2.2",
    "zustand": "^5.0.4"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@hey-api/openapi-ts": "^0.67.3",
    "@react-native-community/cli": "latest",
    "@types/react": "~19.0.10",
    "eslint": "^9.25.0",
    "eslint-config-expo": "~9.2.0",
    "typescript": "~5.8.3"
  },
  "private": true
}
