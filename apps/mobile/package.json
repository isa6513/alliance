{
  "name": "@alliance/mobile",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "packageManager": "yarn@4.9.1",
  "installConfig": {
    "hoistingLimits": "workspaces"
  },
  "scripts": {
    "start": "expo start --dev-client",
    "reset-project": "node ./scripts/reset-project.js",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "lint": "expo lint",
    "gen-api": "yarn openapi-ts",
    "eas-build-pre-install": "corepack enable && corepack prepare yarn@4.9.1 --activate",
    "build:simulator": "npx expo prebuild && cd ios && pod install && cd .. && npx expo run:ios",
    "build:simulator:clean": "npx expo prebuild --clean && cd ios && pod install && cd .. && npx expo run:ios",
    "build:device": "npx expo prebuild && cd ios && pod install && cd .. && npx expo run:ios --device 00008150-001528163445401C",
    "build:android": "npx expo prebuild -p android && npx expo run:android",
    "build:prod": "APP_VARIANT=production npx expo prebuild --clean && cd ios && pod repo update && pod install && cd .. && open ios/*.xcworkspace"
  },
  "dependencies": {
    "@alliance/shared": "workspace:*",
    "@hey-api/client-fetch": "^0.10.0",
    "@legendapp/list": "^2.0.19",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-navigation/bottom-tabs": "^7.3.10",
    "@react-navigation/drawer": "^7.3.9",
    "@react-navigation/elements": "^2.9.5",
    "@react-navigation/native": "^7.1.6",
    "@react-navigation/native-stack": "^7.3.10",
    "@tanstack/react-query": "^5.90.20",
    "expo": "^55.0.6",
    "expo-application": "~55.0.9",
    "expo-blur": "~55.0.9",
    "expo-clipboard": "^55.0.9",
    "expo-constants": "~55.0.7",
    "expo-dev-client": "~55.0.16",
    "expo-device": "~55.0.9",
    "expo-file-system": "~55.0.10",
    "expo-font": "~55.0.4",
    "expo-haptics": "^55.0.9",
    "expo-image": "~55.0.6",
    "expo-image-picker": "~55.0.12",
    "expo-linking": "~55.0.7",
    "expo-localization": "~55.0.8",
    "expo-notifications": "~55.0.12",
    "expo-router": "~55.0.5",
    "expo-secure-store": "~55.0.8",
    "expo-splash-screen": "~55.0.10",
    "expo-status-bar": "~55.0.4",
    "expo-symbols": "~55.0.5",
    "expo-system-ui": "~55.0.9",
    "expo-video": "~55.0.11",
    "expo-web-browser": "~55.0.9",
    "lucide-react-native": "^0.562.0",
    "posthog-react-native": "^4.17.2",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.2",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-keyboard-controller": "1.20.7",
    "react-native-localize": "^3.6.1",
    "react-native-markdown-display": "^7.0.2",
    "react-native-qrcode-svg": "^6.3.4",
    "react-native-reanimated": "^4.2.2",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-svg": "15.15.3",
    "react-native-web": "^0.21.0",
    "react-native-webview": "13.16.0",
    "react-native-worklets": "0.7.2",
    "tailwindcss": "^4.1.18",
    "uniwind": "^1.2.2",
    "zustand": "^5.0.4"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@hey-api/openapi-ts": "^0.67.3",
    "@react-native-community/cli": "latest",
    "@types/react": "~19.2.10",
    "eslint": "^9.25.0",
    "eslint-config-expo": "~55.0.0",
    "typescript": "~5.9.2"
  },
  "private": true
}
